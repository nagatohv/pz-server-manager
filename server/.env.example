# --- CONFIGURACIÓN DEL PORTAL WEB Y JUEGO ---

# Puerto en el que corre el panel web (por defecto: 3000)
PORT=3000

# Contraseña de acceso maestro para el panel web (¡Cámbiame!)
ADMIN_PASSWORD=admin

# Clave secreta para firmar los tokens de sesión JWT
JWT_SECRET=super-secret-pz-token-key-change-me

# --- CONFIGURACIÓN DE PROJECT ZOMBOID ---

# Nombre del servidor y de los archivos de configuración (.ini, .lua)
SERVER_NAME=servertest

# Rama del juego en Steam (vacío para estable Build 41, o "unstable" para Build 42)
STEAMAPPBRANCH=unstable

# --- ASIGNACIÓN DE MEMORIA JVM (Java Virtual Machine) ---
JVM_MIN_GB=4
JVM_MAX_GB=8

# --- DIRECTORIO DE DATOS PERSISTENTES ---
# En producción (Docker/Dokploy), este valor debe ser /home/steam/data
# Para desarrollo local (Windows/Mac), puedes usar una ruta relativa para almacenar datos localmente:
DATA_DIR=../data
